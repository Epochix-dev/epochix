{
  "name": "epochix",
  "displayName": "Epochix",
  "description": "See what your model is doing — training logs become a plain-English story with a letter grade, in a live animated dashboard. No code changes.",
  "publisher": "epochix",
  "version": "0.5.27",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/epochix-dev/epochix"
  },
  "bugs": {
    "url": "https://github.com/epochix-dev/epochix/issues"
  },
  "homepage": "https://github.com/epochix-dev/epochix#readme",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Visualization",
    "Data Science",
    "Machine Learning"
  ],
  "keywords": [
    "machine learning",
    "deep learning",
    "training",
    "visualization",
    "dashboard",
    "pytorch",
    "tensorflow",
    "keras",
    "pytorch lightning",
    "huggingface",
    "yolo",
    "mlops",
    "experiment tracking",
    "training monitor",
    "tensorboard",
    "loss curve"
  ],
  "activationEvents": [
    "onCommand:epochix.openDashboard",
    "onCommand:epochix.watchTerminal",
    "onLanguage:python",
    "onView:epochixRuns",
    "workspaceContains:**/*.log"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "epochix.openDashboard",
        "title": "Epochix: Open Dashboard",
        "icon": "$(graph)"
      },
      {
        "command": "epochix.watchTerminal",
        "title": "Epochix: Watch Active Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "epochix.openLogFile",
        "title": "Epochix: Open Log File…",
        "icon": "$(file-text)"
      },
      {
        "command": "epochix.exportRun",
        "title": "Epochix: Export Current Run",
        "icon": "$(export)"
      },
      {
        "command": "epochix.compareRuns",
        "title": "Epochix: Compare Two Runs",
        "icon": "$(diff)"
      },
      {
        "command": "epochix.tryDemo",
        "title": "Epochix: Try a Demo Run",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "epochix.openLogFile",
          "when": "resourceExtname == .log",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "epochix.openLogFile",
          "when": "resourceExtname == .log",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "epochix.openDashboard",
          "when": "view == epochixRuns",
          "group": "navigation@1"
        },
        {
          "command": "epochix.watchTerminal",
          "when": "view == epochixRuns",
          "group": "navigation@2"
        },
        {
          "command": "epochix.openLogFile",
          "when": "view == epochixRuns",
          "group": "navigation@3"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "epochix",
          "title": "Epochix",
          "icon": "media/epochix.svg"
        }
      ]
    },
    "views": {
      "epochix": [
        {
          "id": "epochixRuns",
          "name": "Runs"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "epochixRuns",
        "contents": "Visualise a training run as an animated dashboard.\n\n[▶ Try a Demo Run](command:epochix.tryDemo)\n\nNo setup needed — see it working on a bundled training log.\n\n[Open Dashboard](command:epochix.openDashboard)\n\n[Watch Active Terminal](command:epochix.watchTerminal)\n\n[Open Log File…](command:epochix.openLogFile)\n\nA run also opens automatically when training is detected in a terminal.\nTip: $(keyboard) Ctrl+Alt+M (⌘⌥M on macOS) opens the dashboard anywhere."
      }
    ],
    "walkthroughs": [
      {
        "id": "epochix.gettingStarted",
        "title": "Get started with Epochix",
        "description": "See a training run as an animated, plain-English story — in under a minute, no setup.",
        "steps": [
          {
            "id": "epochix.step.demo",
            "title": "Watch a demo run",
            "description": "No Python, no data, no training script — see the dashboard on a bundled Keras run, architecture panel and all.\n[Try a Demo Run](command:epochix.tryDemo)",
            "media": {
              "image": "icon.png",
              "altText": "The Epochix dashboard"
            },
            "completionEvents": [
              "onCommand:epochix.tryDemo"
            ]
          },
          {
            "id": "epochix.step.watch",
            "title": "Watch your own training",
            "description": "Run your training script in the integrated terminal — the dashboard opens by itself when Epochix recognises training output (Keras, PyTorch Lightning, YOLO, HuggingFace, fastai, or plain key=value logs).\n[Watch Active Terminal](command:epochix.watchTerminal)",
            "media": {
              "image": "icon.png",
              "altText": "Terminal training detection"
            },
            "completionEvents": [
              "onCommand:epochix.watchTerminal"
            ]
          },
          {
            "id": "epochix.step.logfile",
            "title": "Open a finished log",
            "description": "Already have a training log? Open it and get the full story after the fact — phases, grades, milestones and narrative.\n[Open Log File…](command:epochix.openLogFile)",
            "media": {
              "image": "icon.png",
              "altText": "Open a log file"
            },
            "completionEvents": [
              "onCommand:epochix.openLogFile"
            ]
          },
          {
            "id": "epochix.step.engine",
            "title": "Optional: add the Python engine",
            "description": "Everything above works with the extension alone. Installing the Python package adds run history, run comparison and JSON/HTML/PDF exports:\n``pip install epochix``\nThe extension finds it automatically the next time it starts.",
            "media": {
              "image": "icon.png",
              "altText": "pip install epochix"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "Epochix",
      "properties": {
        "epochix.autoWatchTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the dashboard when ML training is detected in an integrated terminal."
        },
        "epochix.taskHint": {
          "type": "string",
          "enum": [
            "auto",
            "classification",
            "detection",
            "regression",
            "biometric",
            "gaze",
            "nlp"
          ],
          "default": "auto",
          "description": "Force a task type instead of auto-detecting from the log."
        },
        "epochix.useSidecar": {
          "type": "string",
          "enum": [
            "auto",
            "always",
            "never"
          ],
          "default": "auto",
          "description": "Use the Python epochix package as a sidecar server if available."
        },
        "epochix.sidecarPath": {
          "type": "string",
          "default": "",
          "description": "Override the path to the epochix executable."
        },
        "epochix.llmFallback": {
          "type": "boolean",
          "default": false,
          "description": "Enable Ollama LLM fallback parsing for unknown log formats (requires Ollama running locally)."
        },
        "epochix.theme": {
          "type": "string",
          "enum": [
            "auto",
            "light",
            "dark"
          ],
          "default": "auto",
          "description": "Dashboard theme. 'auto' follows VS Code's colour theme."
        },
        "epochix.locale": {
          "type": "string",
          "enum": [
            "en",
            "fa",
            "fr"
          ],
          "default": "en",
          "description": "Dashboard language."
        }
      }
    },
    "keybindings": [
      {
        "command": "epochix.openDashboard",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m"
      }
    ]
  },
  "scripts": {
    "build:webview": "npm --prefix ../frontend run build:webview",
    "compile": "node esbuild.config.mjs",
    "compile:prod": "node esbuild.config.mjs --production",
    "watch": "node esbuild.config.mjs --watch",
    "vscode:prepublish": "npm run build:webview && npm run compile:prod",
    "package": "vsce package",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run compile && tsc -p ./tsconfig.test.json",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.92.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.23.0",
    "eslint": "^8.0.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "typescript": "^5.5.0"
  }
}
